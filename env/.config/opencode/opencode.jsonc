{
  "$schema": "https://opencode.ai/config.json",
  "model": "anthropic/claude-sonnet-4.6",
  "theme": "rose-pine-tp",
  "provider": {
    "litellm": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LiteLLM",
      "options": {
        "baseURL": "https://litellm.talqui.chat/v1"
      },
      "models": {
        "gpt-5.3-codex": {
          "name": "gpt-5.3-codex",
          "reasoningEffort": "medium"
        },
        "gpt-5.4": {
          "name": "gpt-5.4",
          "reasoningEffort": "medium"
        }
      }
    }
  }
}
